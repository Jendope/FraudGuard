# .env.example — copy this to .env and fill in the required values.
#
# ──────────────────────────────────────────────────────────────────
# This is the SINGLE source of truth for all environment variables.
# Both the backend and the web interface read from this file.
# ──────────────────────────────────────────────────────────────────

# Required — Alibaba Cloud DashScope (Qwen LLM + Qwen VL OCR)
# -------------------------------------------------------
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Required — BigModel / ZhipuAI (GLM-OCR alternative + GLM-5 alternative LLM)
# ------------------------------------------------------------------
BIGMODEL_API_KEY=your_bigmodel_api_key_here

# LLM model — change freely; we rotate Qwen free-tier models often
# Supported: any Qwen model slug via DashScope (e.g. qwen3.5-plus, qwen-plus, qwen-turbo)
#            or "glm5/glm5-llm" to use GLM-5 via BigModel instead
# -----------------------------------------------------------------------
LLM_MODEL=qwen3.5-plus

# OCR model — default uses Qwen VL OCR via DashScope
# Alternative: "glm-ocr" to use GLM-OCR via BigModel instead
OCR_MODEL=qwen-vl-ocr-2025-11-20

# Optional — LLM / RAG
DEFAULT_MODE=raw
EMBED_MODEL=BAAI/bge-large-zh-v1.5
RAG_TOP_K=3

# Optional — ChromaDB path (set automatically by Docker Compose)
# CHROMA_DB_PATH=/app/chroma_hk01_scam_db

# ──────────────────────────────────────────────────────────────────
# Frontend (Next.js) variables
# ──────────────────────────────────────────────────────────────────

# ZhipuAI SDK — uses the same key as BIGMODEL_API_KEY
ZAI_API_KEY=your_bigmodel_api_key_here
ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Backend API URL — the web interface calls this for RAG mode
NEXT_PUBLIC_API_BASE=http://localhost:5000
# GitHub repository URL — update here when the repo URL changes
NEXT_PUBLIC_GITHUB_REPO_URL=https://github.com/Jendope/allinone

# .env.example — copy this to .env and fill in the required values.
#
# Required
# --------
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Optional — Whisper speech-to-text
# Values: tiny | base | small | medium | large  (default: base)
WHISPER_MODEL=base
# Values: cpu | cuda  (default: cpu)
WHISPER_DEVICE=cpu
# ISO-639-1 language hint, e.g. en, zh, ja — leave blank for auto-detect
WHISPER_LANGUAGE=

# Optional — LLM / RAG
DEFAULT_MODE=raw
OCR_MODEL=zai-org/GLM-OCR
LLM_MODEL=deepseek/deepseek-llm
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_TOP_K=3

# Optional — ChromaDB path (set automatically by Docker Compose)
# CHROMA_DB_PATH=/app/rag-pipeline/chroma_hk01_scam_db

# Optional — Frontend build
# Override when deploying behind a custom domain; leave blank to use the nginx proxy.
VITE_API_BASE=

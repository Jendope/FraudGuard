# Backend .dockerignore — exclude files that should not be copied into the image.

# Python artefacts
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage

# Virtual environments
.venv/
venv/
env/

# Test files (not needed in production image)
tests/

# Development & CI config
.env
.env.*
*.env

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# Git
.git/
.gitignore
.gitattributes

# OS
.DS_Store
Thumbs.db

# Docker
Dockerfile
.dockerignore
